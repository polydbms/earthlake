OPENAI_API_KEY=<<INSERT OPENAI API KEY HERE>>

# === Remote Benchmark Execution ===
# Set to "slurm" to route benchmarks to pluto, "local" to run locally.
BENCHMARK_EXECUTOR=slurm

# === SLURM Remote Execution ===
SLURM_HOST=pluto.rsim.tu-berlin.de
SLURM_USER=remsa-benchmarker
SLURM_PASSWORD=
SLURM_WORK_DIR=/home/remsa-benchmarker/benchmarks

# Find partition: ssh into server and run: sinfo -o "%P"
SLURM_PARTITION=LocalQ

# SLURM account to charge jobs to (run: sacctmgr show accounts)
SLURM_ACCOUNT=rsim-member

# Path to conda/mamba base install on the remote server.
# Used to source conda.sh so 'conda activate' works in non-interactive SLURM jobs.
SLURM_CONDA_BASE=/home/remsa-benchmarker/miniforge3

# Find conda env with terratorch: ssh and run: conda env list
SLURM_CONDA_ENV=terratorch

# Space-separated modules to load before job (optional).
# Find available modules: ssh and run: module avail
SLURM_MODULES=

# ── Model Weight Cache ────────────────────────────────────────────
# ./model_weights is auto-created on first run and persists across restarts.
# Auto-download models (Prithvi, Clay, etc.) cache here automatically via HF_HOME.
# Fine-tuned checkpoints from 'fit' mode are saved here and reused on re-run.
#
# SatMAE requires one-time manual setup:
#   mkdir -p model_weights/satmae/{repo,checkpoints}
#   git clone https://github.com/sustainlab-group/SatMAE model_weights/satmae/repo
#   # Place pretrained-vit-base-e199.pth / pretrained-vit-large-e199.pth
#   # into model_weights/satmae/checkpoints/
