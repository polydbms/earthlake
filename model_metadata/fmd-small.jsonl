{"model_id":"clay_v1_base","model_name":"Clay","version":"v1-base","release_date":"2024-04-19","last_updated":"2024-04-19","short_description":"Clay is an open-source, multi-sensor Vision Transformer foundation model for Earth observation. It is trained using masked autoencoding and uniquely incorporates embeddings for space (Ground Sample Distance), time, and physical wavelengths, allowing it to dynamically ingest varying sensors, resolutions, and temporal gaps without structural changes to the architecture.","paper_link":null,"citations":null,"repository":"https://github.com/made-with-clay/clay","weights":"https://huggingface.co/made-with-clay/Clay","backbone":"ViT (Vision Transformer) with dynamic spatial, temporal, and wavelength embeddings","num_layers":12,"num_parameters":100,"pretext_training_type":"Masked Autoencoder (MAE) self-supervised learning","masking_strategy":"Random masking of patches during pretraining (default MAE strategies)","pretraining":"Self-supervised masked autoencoding on a massive, diverse multi-sensor dataset spanning multiple resolutions, sensor types (optical, SAR, aerial), and global geographic regions.","domain_knowledge":["Continuous wavelength encoding (dynamic band processing)","Spatial resolution (Ground Sample Distance / GSD) embedding","Temporal embedding (date and time awareness)","Latitudinal/Longitudinal position encoding"],"backbone_modifications":["Wavelength embeddings per channel","GSD embeddings per patch","Positional encoding combined with time and location metadata"],"supported_sensors":["Sentinel-2 MSI","Sentinel-1 SAR","Landsat 8/9","NAIP","LINZ"],"modality_integration_type":"Multimodal (Dynamic/Agnostic)","modalities":["Multispectral","SAR","Aerial RGB"],"spectral_alignment":"Dynamic (via continuous wavelength embeddings)","temporal_alignment":"Dynamic (via explicit time metadata)","spatial_resolution":"Variable (native support for anything from 0.1m to 60m+)","temporal_resolution":"Variable","bands":"Dynamic (accepts any specified wavelengths)","pretraining_phases":[{"dataset":"Diverse multi-sensor STAC catalogs (Sentinel, Landsat, NAIP, LINZ)","regions_coverage":["Global"],"time_range":"Multi-year","num_images":null,"token_size":"patch size 8x8 (scaled internally depending on GSD)","image_resolution":"224x224 (dynamic during fine-tuning)","epochs":null,"batch_size":null,"learning_rate":null,"augmentations":[],"processing":["STAC item sampling","Dynamic patch generation","Metadata extraction (GSD, wavelength, time, location)"],"sampling":"Spatio-temporally stratified STAC sampling","processing_level":"Variable (L1C, L2A, ARD)","cloud_cover":"Variable","missing_data":"Handled dynamically via MAE structure","masking_ratio":null}],"benchmarks":[{"task":"Segmentation","application":"Flood mapping","dataset":"Sen1Floods11","metrics":["IoU (water)"],"metrics_value":[null],"sensor":["Sentinel-2","Sentinel-1"],"regions":["Global (6 continents, 11 flood events)"],"original_samples":4831,"num_samples":null,"sampling_percentage":null,"num_classes":2,"classes":["water","non-water"],"image_resolution":"512x512","spatial_resolution":"10m","bands_used":"Dynamic","augmentations":[],"optimizer":"AdamW","batch_size":null,"learning_rate":null,"epochs":null,"loss_function":"Dice/Cross Entropy","split_ratio":null}]}